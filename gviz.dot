digraph packages {
  size="10"; ratio=fill;
  ai_box [shape="box"; color="#3ac239"];
  chatgpt_box [shape="box"; color="#07cf0e"];
  claude_box [shape="box"; color="#e4f40c"];
  deepseek_box [shape="box"; color="#123782"];
  gemini_box [shape="box"; color="#0e171e"];
  grok_box [shape="box"; color="#ac07ba"];
  minimax_box [shape="box"; color="#df6549"];
  openrouter_box [shape="box"; color="#bea045"];
  chatgpt_box -> ai_box [style="filled"; color="#3ac239"];
  claude_box -> ai_box [style="filled"; color="#3ac239"];
  deepseek_box -> ai_box [style="filled"; color="#3ac239"];
  gemini_box -> ai_box [style="filled"; color="#3ac239"];
  grok_box -> ai_box [style="filled"; color="#3ac239"];
  minimax_box -> ai_box [style="filled"; color="#3ac239"];
  openrouter_box -> ai_box [style="filled"; color="#3ac239"];
  subgraph "cluster pkgs" {
    label="pkgs";
    color="#7c6413";
    ai_box;
    chatgpt_box;
    claude_box;
    deepseek_box;
    gemini_box;
    grok_box;
    minimax_box;
    openrouter_box;
  }
}
